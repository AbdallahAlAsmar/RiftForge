NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# Riot RSO / OAuth app credentials
RIOT_CLIENT_ID=
RIOT_CLIENT_SECRET=
RIOT_REDIRECT_URI=http://localhost:3000/auth/callback

# Local testing bypass for Riot RSO (dev only)
# Set to true to skip real Riot OAuth and create/sign in a deterministic mock Riot user.
RIOT_DEV_MOCK=false
RIOT_DEV_MOCK_GAME_NAME=DevSummoner
RIOT_DEV_MOCK_TAG_LINE=EUW

# Strong random server secret used only to bridge Riot OAuth into Supabase Auth.
APP_AUTH_SECRET=replace-with-32-plus-random-chars
